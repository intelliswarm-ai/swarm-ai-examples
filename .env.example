# =============================================================================
# SwarmAI Examples — Central Configuration Template
# =============================================================================
# Copy this file to `.env` (gitignored) and fill in only the keys for the
# examples you plan to run. Spring Boot auto-loads `.env` via
# ParentDirDotenvPostProcessor — no `source` / `export` needed.
#
# Each example's README also lists the vars it needs and where to obtain them.
# =============================================================================

# --- LLM Provider (pick one) ------------------------------------------------
# Ollama (default — local, no API key). Just run `ollama serve`.
OLLAMA_MODEL=mistral:latest
SPRING_AI_OLLAMA_CHAT_OPTIONS_MODEL=mistral:latest
SPRING_PROFILES_ACTIVE=ollama

# OpenAI  — https://platform.openai.com/api-keys
#   Used by: image-gen example, any workflow with SPRING_PROFILES_ACTIVE=openai*
#   Profiles available:
#     openai       → gpt-4o          (high quality, higher cost)
#     openai-mini  → gpt-4o-mini     (RECOMMENDED — ~95% cheaper, great for most workflows)
#     openai-o3    → o3-mini         (reasoning model, temperature locked to 1.0)
#   Override the workflow model with OPENAI_WORKFLOW_MODEL=gpt-4.1-mini etc.
#OPENAI_API_KEY=sk-proj-...
#SPRING_AI_OPENAI_API_KEY=sk-proj-...
#OPENAI_WORKFLOW_MODEL=gpt-4o-mini

# Anthropic — https://console.anthropic.com/settings/keys
#ANTHROPIC_API_KEY=sk-ant-api03-...
#SPRING_AI_ANTHROPIC_API_KEY=sk-ant-api03-...

# =============================================================================
# Core search / data APIs (pre-existing examples)
# =============================================================================

# Alpha Vantage — free tier: https://www.alphavantage.co/support/#api-key
#   Used by: stock-analysis, due-diligence, investment-*
ALPHA_VANTAGE_API_KEY=

# Google Custom Search — https://developers.google.com/custom-search/v1/overview
#   1) Create API key at https://console.cloud.google.com/apis/credentials
#   2) Create a Programmable Search engine at https://programmablesearchengine.google.com/
#   Used by: web-research, competitive-analysis, self-improving, etc.
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Bing Search — https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_API_KEY=

# NewsAPI — https://newsapi.org/register  (free: 100 req/day, dev-only)
NEWSAPI_KEY=

# Finnhub — https://finnhub.io/register  (free tier covers examples)
FINNHUB_API_KEY=

# SerpAPI — https://serpapi.com/ (optional Google alternative)
#SERP_API_KEY=

# --- wikipedia-research -----------------------------------------------------
#   No keys required. Public Wikipedia REST API.
#   Run: ./run.sh wikipedia "Ada Lovelace"

# --- arxiv-paper-search -----------------------------------------------------
#   No keys required. arXiv public Atom feed (rate-limit ~1 req / 3 s per IP).
#   Run: ./run.sh arxiv "transformer interpretability"

# --- openapi-universal-client -----------------------------------------------
#   No keys required by default (hits the public Swagger Petstore sandbox).
#   If your spec is authenticated, pass `bearer_token` per tool call.
#   Run: ./run.sh openapi

# --- spring-data-repository-agent -------------------------------------------
#   No keys required. Embedded H2 + @ConditionalOnProperty.
#   Run: ./run.sh spring-data "how many customers are on the PRO tier?"

# --- wolfram-alpha-math -----------------------------------------------------
#   Get free App ID (2000 req/mo) at https://developer.wolframalpha.com/
#   Dashboard → "Get an AppID" → copy the AppID string.
WOLFRAM_APPID=

# --- openweathermap-forecast ------------------------------------------------
#   Free tier (60 req/min): https://openweathermap.org/api
#   1) Sign up, 2) confirm email, 3) copy key from https://home.openweathermap.org/api_keys
#   New keys take up to 2 h to activate; 401 before then is expected.
OPENWEATHER_API_KEY=

# --- image-generation-dalle -------------------------------------------------
#   Needs OPENAI_API_KEY (see LLM Provider section above). ~$0.040/image for
#   DALL-E 3 1024×1024. Uncomment OPENAI_API_KEY above before running.
#   Run: ./run.sh image-gen "a minimalist vector logo for an AI startup"

# --- jira-ticket-management -------------------------------------------------
#   Cloud: JIRA_BASE_URL=https://<your-org>.atlassian.net
#          API token: https://id.atlassian.com/manage-profile/security/api-tokens
#   Self-hosted: spin up atlassian/jira-software in Docker (see README).
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
#JIRA_TEST_PROJECT=ACME

# --- pinecone-vector-rag ----------------------------------------------------
#   Free starter tier (no credit card): https://app.pinecone.io
#   1) Sign up → create an index (e.g. dim=8 for this demo).
#   2) Copy API key from "API Keys" tab.
#   3) Copy HOST url from the index's "CONNECT" panel (starts with https://).
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
#PINECONE_INDEX_DIM=8
#PINECONE_TEST_NAMESPACE=swarmai-example

# --- s3-cloud-storage -------------------------------------------------------
#   Option A — real AWS:
#     1) IAM user with s3:{Put,Get,List,Delete}Object on the bucket.
#     2) Create the bucket in your preferred region.
#     3) Either set the three AWS_* vars below or populate ~/.aws/credentials.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_TEST_BUCKET=
#   Option B — LocalStack (no AWS account, fully local):
#     docker run --rm -it -p 4566:4566 -e SERVICES=s3 localstack/localstack:latest
#     aws --endpoint-url=http://localhost:4566 s3 mb s3://swarmai-test-bucket
#     (then use the placeholder values below)
#AWS_REGION=us-east-1
#AWS_ACCESS_KEY_ID=test
#AWS_SECRET_ACCESS_KEY=test
#AWS_ENDPOINT_URL_S3=http://localhost:4566
#S3_TEST_BUCKET=swarmai-test-bucket

# --- kafka-event-publishing -------------------------------------------------
#   Local single-broker dev cluster:
#     docker run --rm -d --name kafka -p 9092:9092 apache/kafka:3.7.1
#   Then create the topic (see kafka-event-publishing/README.md).
KAFKA_BOOTSTRAP_SERVERS=
#KAFKA_TEST_TOPIC=swarmai-events

# =============================================================================
# Workflow Defaults (used when no CLI args are passed)
# =============================================================================
WORKFLOW=stock-analysis
WORKFLOW_ARGS=AAPL
