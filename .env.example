# =============================================================================
# SwarmAI Examples — Central Configuration
# =============================================================================
# Copy this file or set these variables in your environment.
# For Docker: these are automatically loaded by docker-compose.
# For local:  source this file or export the variables manually.
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Ollama (default for Docker)
OLLAMA_MODEL=mistral:7b

# OpenAI (uncomment to use instead of Ollama)
#SPRING_AI_OPENAI_API_KEY=sk-...

# Anthropic (uncomment to use instead of Ollama)
#SPRING_AI_ANTHROPIC_API_KEY=sk-ant-...

# --- Search & Data APIs -----------------------------------------------------
# At least one search key is required for data-dependent workflows:
#   stock-analysis, competitive-analysis, due-diligence, iterative-memo,
#   web-research, self-improving, enterprise-governed, competitive-swarm,
#   investment-swarm

# Alpha Vantage (free tier: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# SerpAPI (https://serpapi.com/)
#SERP_API_KEY=

# --- Workflow Defaults -------------------------------------------------------
WORKFLOW=stock-analysis
WORKFLOW_ARGS=AAPL
