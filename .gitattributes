# Normalize line endings to LF on commit, checkout as native
* text=auto eol=lf

# Explicitly mark these as text
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.sh text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Windows batch files need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
